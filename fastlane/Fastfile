default_platform(:ios)

require "shellwords"

# Use the project wrapper `bin/fastlane ...` rather than `bundle exec fastlane ...`
# and instead of calling `tuist generate` directly, call `bin/fastlane generate`
# so agents can stay on a consistent, approved command surface.

platform :ios do
  DEFAULT_SIM_DESTINATION = 'platform=iOS Simulator,name=iPhone 17 Pro'.freeze

  desc "Run SwiftLint (optionally scoped via path:)"
  lane :lint do |options|
    raw_path = options[:path].to_s.strip
    repo_root = File.expand_path("..", __dir__)

    lint_paths = if raw_path.empty?
                   []
                 else
                   raw_path.split(",").map(&:strip).reject(&:empty?).flat_map do |candidate|
                     if candidate.match?(/[\*\?\[\{]/)
                       Dir.glob(File.join(repo_root, candidate)).map { |p| p.sub("#{repo_root}/", "") }
                     else
                       expanded_path = File.expand_path(candidate, repo_root)
                       if File.exist?(expanded_path)
                         [expanded_path.sub("#{repo_root}/", "")]
                       else
                         UI.user_error!("Path not found for lint: #{candidate}")
                       end
                     end
                   end.uniq
                 end

    if !raw_path.empty? && lint_paths.empty?
      UI.user_error!("No files matched path: #{raw_path}")
    end

    lint_command = "cd .. && swiftlint lint --strict --config .swiftlint.yml --quiet"
    unless lint_paths.empty?
      escaped_paths = lint_paths.map { |lint_path| Shellwords.shellescape(lint_path) }.join(" ")
      lint_command = "#{lint_command} #{escaped_paths}"
    end

    sh lint_command
  end

  desc "Format Swift code (optionally scoped via path:)"
  lane :format_code do |options|
    path = (options[:path] || ".").to_s
    repo_root = File.expand_path("..", __dir__)

    if path.match?(/[\*\?\[]/)
      matches = Dir.glob(File.join(repo_root, path))
      UI.user_error!("No files matched path: #{path}") if matches.empty?

      rel_paths = matches.map { |p| p.sub("#{repo_root}/", "") }
      escaped_paths = rel_paths.map { |p| Shellwords.shellescape(p) }.join(" ")
      sh "cd .. && swift-format -i #{escaped_paths} --configuration .swift-format.json"
    else
      sh "cd .. && swift-format -i -r #{Shellwords.shellescape(path)} --configuration .swift-format.json"
    end
  end

  desc "Format Swift code (alias)"
  lane :format do |options|
    format_code(options)
  end

  desc "Generate Xcode project with Tuist"
  lane :generate do
    sh "cd .. && unset CPATH; tuist generate"
  end

  desc "Run unit tests"
  lane :test_unit do
    destination = (ENV["SIM_DESTINATION"] || DEFAULT_SIM_DESTINATION).to_s
    sh "cd .. && unset CPATH; xcodebuild test -project LittleMoments.xcodeproj -scheme \"LittleMoments\" -configuration Debug -sdk iphonesimulator -destination \"#{destination}\" -only-testing:LittleMomentsTests"
  end

  desc "Run UI tests"
  lane :test_ui do
    destination = (ENV["SIM_DESTINATION"] || DEFAULT_SIM_DESTINATION).to_s
    sh "cd .. && unset CPATH; xcodebuild test -project LittleMoments.xcodeproj -scheme \"LittleMoments-UI\" -configuration Debug -sdk iphonesimulator -destination \"#{destination}\""
  end

  desc "Run all tests"
  lane :test do
    test_unit
    test_ui
  end

  desc "Run a subset of tests via targets: (comma-separated)"
  lane :test_targets do |options|
    targets = (options[:targets] || "").to_s.split(",").map(&:strip).reject(&:empty?)
    if targets.empty?
      UI.user_error!("Provide targets:, e.g. targets:'LittleMomentsTests,LittleMomentsUITests'")
    end

    run_unit = targets.include?("LittleMomentsTests")
    run_ui = targets.include?("LittleMomentsUITests")

    unknown = targets - ["LittleMomentsTests", "LittleMomentsUITests"]
    UI.user_error!("Unknown targets: #{unknown.join(", ")}") unless unknown.empty?

    test_unit if run_unit
    test_ui if run_ui
  end

  desc "Run tests using an Xcode test plan"
  lane :test_plan do |options|
    plan = (options[:plan] || "").to_s.strip
    UI.user_error!("Provide plan:, e.g. plan:'Default'") if plan.empty?

    scheme = (options[:scheme] || "LittleMoments").to_s
    destination = (options[:destination] || ENV["SIM_DESTINATION"] || DEFAULT_SIM_DESTINATION).to_s

    sh "cd .. && unset CPATH; xcodebuild test -project LittleMoments.xcodeproj -scheme #{Shellwords.shellescape(scheme)} -configuration Debug -sdk iphonesimulator -destination #{Shellwords.shellescape(destination)} -testPlan #{Shellwords.shellescape(plan)}"
  end

  desc "Build app with Tuist"
  lane :build do
    begin
      sh "cd .. && unset CPATH; tuist build"
    rescue => e
      UI.important("Tuist build failed, attempting device build via xcodebuild as fallback…")
      # Build for a generic iOS Device to avoid simulator SDK module map issues
      sh "cd .. && unset CPATH; xcodebuild build -project LittleMoments.xcodeproj -scheme \"LittleMoments\" -configuration Debug -sdk iphoneos -destination \"generic/platform=iOS\""
    end
  end

  desc "Format, lint, test, and build"
  lane :quality_check do
    format_code
    lint
    test
    build
  end

  desc "CI: build + test on Simulator"
  lane :ci do
    scheme = ENV["SCHEME"] || "LittleMoments"
    ui_scheme = ENV["UI_SCHEME"] || "LittleMoments-UI"
    device = ENV["DEVICE"] || "iPhone 17 Pro"
    destination = (ENV["SCAN_DESTINATION"] || "").strip
    destination = nil if destination.empty?

    unit_scan_options = {
      scheme: scheme,
      clean: true,
      result_bundle_path: "build/UnitTests.xcresult"
    }

    ui_scan_options = {
      scheme: ui_scheme,
      clean: false,
      result_bundle_path: "build/UITests.xcresult"
    }

    if destination
      unit_scan_options[:destination] = destination
      ui_scan_options[:destination] = destination
    else
      unit_scan_options[:device] = device
      ui_scan_options[:device] = device
    end

    scan(unit_scan_options)
    scan(ui_scan_options)
  end

  desc "Generate repository overview with Repomix"
  lane :repomix do
    sh "cd .. && repomix"
  end
end
