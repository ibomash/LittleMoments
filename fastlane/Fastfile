default_platform(:ios)

# Use `fastlane ...` directly rather than `bundle exec fastlane ...`
# and instead of calling `tuist generate` directly, call `fastlane generate`
# so that the agent can run fastlane commands without having to approve every command.

platform :ios do
  # Fail early if the selected Xcode is older than 16 (iOS 18 SDK required)
  private_lane :assert_xcode_16 do
    version_output = sh("xcodebuild -version", log: false).to_s
    match = version_output.match(/Xcode\s+(\d+)(?:\.(\d+))?/)
    unless match
      UI.user_error!("Unable to determine Xcode version. Output: #{version_output}")
    end
    major = match[1].to_i
    if major < 16
      UI.user_error!("Xcode 16+ required for Control Center controls. Found: #{version_output.lines.first.to_s.strip}")
    end
  end

  # Additionally require an SDK that contains ControlCenter.framework
  private_lane :assert_controlcenter_sdk do
    sdk_path = sh("xcrun --sdk iphonesimulator --show-sdk-path", log: false).to_s.strip
    if sdk_path.empty? || !File.directory?(sdk_path)
      UI.user_error!("Unable to locate iOS Simulator SDK path via xcrun. Is Xcode selected?")
    end
    cc_framework = File.join(sdk_path, "System/Library/Frameworks/ControlCenter.framework")
    unless File.directory?(cc_framework)
      if ENV["SKIP_CC_SDK_CHECK"] == "1"
        UI.important("ControlCenter.framework missing in SDK: #{sdk_path}. Proceeding because SKIP_CC_SDK_CHECK=1 is set.")
      else
        UI.user_error!("ControlCenter.framework not found in SDK: #{sdk_path}. Upgrade to an Xcode/iOS SDK that includes Control Center (e.g., Xcode with iOS 18.6 SDK), or re-enable canImport(ControlCenter) guards. Set SKIP_CC_SDK_CHECK=1 to bypass.")
      end
    end
  end

  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      quiet: true,
      strict: true,
      ignore_exit_status: true
    )
  end

  desc "Format Swift code"
  lane :format_code do
    sh "cd .. && swift-format -i -r . --configuration .swift-format.json"
  end

  desc "Generate Xcode project with Tuist"
  lane :generate do
    assert_xcode_16
    assert_controlcenter_sdk
    sh "cd .. && tuist generate"
  end

  desc "Run unit tests"
  lane :test_unit do
    assert_xcode_16
    assert_controlcenter_sdk
    sh "cd .. && xcodebuild test -project LittleMoments.xcodeproj -scheme \"LittleMoments\" -configuration Debug -sdk iphonesimulator -destination \"platform=iOS Simulator,OS=18.6,name=iPhone 16\" -only-testing:LittleMomentsTests"
  end

  desc "Run UI tests"
  lane :test_ui do
    assert_xcode_16
    assert_controlcenter_sdk
    sh "cd .. && xcodebuild test -project LittleMoments.xcodeproj -scheme \"LittleMoments\" -configuration Debug -sdk iphonesimulator -destination \"platform=iOS Simulator,OS=18.6,name=iPhone 16\" -only-testing:LittleMomentsUITests"
  end

  desc "Run all tests"
  lane :test do
    test_unit
    test_ui
  end

  desc "Build app with Tuist"
  lane :build do
    assert_xcode_16
    assert_controlcenter_sdk
    sh "cd .. && xcodebuild build -project LittleMoments.xcodeproj -scheme \"LittleMoments\" -configuration Debug -sdk iphonesimulator -destination \"platform=iOS Simulator,OS=18.6,name=iPhone 16\""
  end

  desc "Format, lint, test, and build"
  lane :quality_check do
    format_code
    lint
    test
    build
  end

  desc "Generate repository overview with Repomix"
  lane :repomix do
    sh "cd .. && repomix"
  end
end 
